{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A resell item available for purchase",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Product name" },
        "price": { "type": "number", "description": "Product price" },
        "description": { "type": "string", "description": "Product description" },
        "imageUrl": { "type": "string", "description": "URL to the product image" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the product was added" }
      },
      "required": ["name", "price", "imageUrl", "createdAt"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for a product",
      "type": "object",
      "properties": {
        "productId": { "type": "string", "description": "ID of the ordered product" },
        "productName": { "type": "string", "description": "Name of the product at time of order" },
        "customerName": { "type": "string", "description": "Customer's full name" },
        "phone": { "type": "string", "description": "Customer's phone number" },
        "address": { "type": "string", "description": "Customer's shipping address" },
        "status": { "type": "string", "enum": ["Pending", "Contacted"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed" }
      },
      "required": ["productId", "productName", "customerName", "phone", "address", "status", "createdAt"]
    },
    "Admin": {
      "title": "Admin",
      "description": "An administrative user",
      "type": "object",
      "properties": {
        "email": { "type": "string", "description": "Admin email" }
      },
      "required": ["email"]
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "Product",
      "description": "Collection of all resell products"
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Collection of customer orders"
    },
    "/admins/{adminId}": {
      "schema": "Admin",
      "description": "List of authorized admin UIDs"
    }
  }
}
