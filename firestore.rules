rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        (request.auth.token.email == "pixelpilots2013@gmail.com" && request.auth.token.email_verified == true)
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Product Validation ---
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'description', 'imageUrl', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.price is number && data.price >= 0 &&
             data.description is string && data.description.size() <= 2000 &&
             data.imageUrl is string && data.imageUrl.size() <= 500 &&
             data.createdAt == request.time;
    }

    // --- Order Validation ---
    function isValidOrder(data) {
      return data.keys().hasAll(['productId', 'productName', 'customerName', 'phone', 'address', 'status', 'createdAt']) &&
             data.keys().size() == 7 &&
             data.productId is string && data.productId.size() <= 128 &&
             data.productName is string && data.productName.size() <= 100 &&
             data.customerName is string && data.customerName.size() >= 2 && data.customerName.size() <= 100 &&
             data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20 &&
             data.address is string && data.address.size() >= 5 && data.address.size() <= 500 &&
             data.status in ['Pending', 'Contacted'] &&
             data.createdAt == request.time;
    }

    // --- Collections ---

    match /products/{productId} {
      allow read: if true; // Public read
      allow create: if isAdmin() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'price', 'description', 'imageUrl', 'createdAt'])
      );
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      allow list: if isAdmin(); // Only admins can list orders
      allow get: if isAdmin(); // Only admins can get specific order
      allow create: if isValidOrder(incoming()) && isValidId(orderId) &&
                   exists(/databases/$(database)/documents/products/$(incoming().productId));
      allow update: if isAdmin() && isValidOrder(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) // Only status can be updated by admin
      );
      allow delete: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Admins managed manually or via specific process
    }
  }
}
